{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.agentnet.ai/agent.schema.json",
  "title": "Agent Definition",
  "description": "AgentNet Protocol V3 Agent 数据结构定义",
  "type": "object",
  "required": ["agent_id", "name", "capabilities"],

  "properties": {
    "agent_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_-]*$",
      "minLength": 3,
      "maxLength": 64,
      "description": "唯一 Agent 标识符"
    },

    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "Agent 显示名称"
    },

    "did": {
      "type": "string",
      "pattern": "^did:agentnet:[a-zA-Z0-9]+$",
      "description": "去中心化身份标识符"
    },

    "public_key": {
      "type": "string",
      "description": "公钥（PEM 格式，用于签名验证）"
    },

    "capabilities": {
      "type": "array",
      "minItems": 1,
      "description": "Agent 提供的能力列表",
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$"
      }
    },

    "status": {
      "type": "string",
      "enum": ["online", "busy", "offline", "draining", "suspended"],
      "default": "offline"
    },

    "metadata": {
      "type": "object",
      "properties": {
        "provider": { "type": "string", "description": "提供组织/个人" },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "description": { "type": "string", "maxLength": 1000 },
        "verified": { "type": "boolean", "default": false },
        "trust_score": { "type": "number", "minimum": 0, "maximum": 1 },
        "website": { "type": "string", "format": "uri" },
        "contact_email": { "type": "string", "format": "email" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": {
          "type": "string",
          "enum": [
            "shopping",
            "coding",
            "research",
            "productivity",
            "communication",
            "data",
            "automation",
            "other"
          ]
        },
        "supported_protocol_versions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "max_concurrent_tasks": { "type": "integer", "minimum": 1 }
      }
    },

    "endpoints": {
      "type": "object",
      "properties": {
        "websocket": { "type": "string", "format": "uri" },
        "rest": { "type": "string", "format": "uri" },
        "capability_endpoint": { "type": "string", "format": "uri" }
      }
    },

    "permissions": {
      "type": "object",
      "description": "Agent 的权限范围",
      "properties": {
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rate_limit": {
          "type": "object",
          "properties": {
            "tasks_per_minute": { "type": "integer" },
            "capability_calls_per_hour": { "type": "integer" }
          }
        }
      }
    },

    "tenant_id": {
      "type": "string",
      "description": "所属租户ID（用于隔离）"
    },

    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" },
    "last_seen_at": { "type": "string", "format": "date-time" }
  },

  "additionalProperties": false
}
