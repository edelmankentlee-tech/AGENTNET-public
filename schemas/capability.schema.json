{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://schemas.agentnet.ai/capability.schema.json",
  "title": "Capability Definition",
  "description": "AgentNet Protocol V3 Capability ж•°жҚ®з»“жһ„е®ҡд№ү",
  "type": "object",
  "required": [
    "capability_id",
    "name",
    "description",
    "version",
    "input_schema",
    "output_schema",
    "risk_level"
  ],

  "properties": {
    "capability_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9]*(\\.[a-z][a-z0-9]*)*$",
      "description": "е”ҜдёҖиғҪеҠӣж ҮиҜҶз¬ҰпјҢж јејҸ: namespace.nameпјҲеҰӮ product.searchпјү"
    },

    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "иғҪеҠӣеҗҚз§°пјҲдёӯж–Үпјү"
    },

    "name_en": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "description": "иғҪеҠӣеҗҚз§°пјҲиӢұж–Үпјү"
    },

    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 1000,
      "description": "иғҪеҠӣиҜҰз»ҶжҸҸиҝ°"
    },

    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "иҜӯд№үеҢ–зүҲжң¬еҸ·пјҲSemVerпјү"
    },

    "provider": {
      "type": "object",
      "required": ["agent_id", "name"],
      "properties": {
        "agent_id": { "type": "string" },
        "name": { "type": "string" },
        "verified": { "type": "boolean", "default": false },
        "website": { "type": "string", "format": "uri" },
        "contact": { "type": "string", "format": "email" }
      }
    },

    "input_schema": {
      "type": "object",
      "description": "иҫ“е…ҘеҸӮж•° JSON Schema",
      "$ref": "http://json-schema.org/draft-07/schema#/definitions/schema"
    },

    "output_schema": {
      "type": "object",
      "description": "иҫ“еҮәз»“жһң JSON Schema",
      "$ref": "http://json-schema.org/draft-07/schema#/definitions/schema"
    },

    "risk_level": {
      "type": "string",
      "enum": ["LOW", "MEDIUM", "HIGH", "CRITICAL"],
      "description": "йЈҺйҷ©зӯүзә§"
    },

    "requires_confirmation": {
      "type": "boolean",
      "default": false,
      "description": "жҳҜеҗҰйңҖиҰҒз”ЁжҲ·зЎ®и®Ө"
    },

    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "description": "и°ғз”ЁжүҖйңҖжқғйҷҗеҲ—иЎЁ",
      "examples": [["capability:call:product.*", "capability:read:analytics"]]
    },

    "pricing": {
      "type": "object",
      "required": ["model"],
      "description": "е®ҡд»·й…ҚзҪ®",
      "oneOf": [
        {
          "properties": {
            "model": { "const": "per_call" },
            "price": { "type": "number", "minimum": 0 },
            "currency": { "type": "string", "default": "USD" },
            "free_tier": {
              "type": "object",
              "properties": {
                "monthly_calls": { "type": "integer", "minimum": 0 },
                "enabled": { "type": "boolean" }
              }
            }
          },
          "required": ["model", "price"]
        },
        {
          "properties": {
            "model": { "const": "flat_rate" },
            "price": { "type": "number", "minimum": 0 },
            "currency": { "type": "string" },
            "period": { "type": "string", "enum": ["month", "year"] },
            "includes_calls": { "type": "integer", "minimum": 0 }
          },
          "required": ["model", "price"]
        },
        {
          "properties": {
            "model": { "const": "subscription" },
            "plans": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": ["number", "null"] },
                  "negotiable": { "type": "boolean" },
                  "calls_per_month": { "type": "integer" }
                }
              }
            }
          },
          "required": ["model", "plans"]
        }
      ]
    },

    "rate_limit": {
      "type": "object",
      "description": "йҖҹзҺҮйҷҗеҲ¶й…ҚзҪ®",
      "properties": {
        "calls_per_minute": { "type": "integer", "minimum": 1 },
        "calls_per_hour": { "type": "integer", "minimum": 1 },
        "calls_per_day": { "type": "integer", "minimum": 1 }
      }
    },

    "metadata": {
      "type": "object",
      "properties": {
        "tags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z][a-z0-9]*$" }
        },
        "category": {
          "type": "string",
          "enum": [
            "ecommerce",
            "productivity",
            "communication",
            "data",
            "ai",
            "security",
            "infrastructure",
            "other"
          ]
        },
        "documentation_url": { "type": "string", "format": "uri" },
        "deprecated": { "type": "boolean", "default": false },
        "deprecation_message": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "status": {
      "type": "string",
      "enum": ["active", "beta", "deprecated", "maintenance", "disabled"],
      "default": "active"
    },

    "created_at": { "type": "string", "format": "date-time" },
    "updated_at": { "type": "string", "format": "date-time" }
  },

  "additionalProperties": false
}
