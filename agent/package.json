{
  "name": "@agentnet/agent",
  "version": "1.0.0",
  "description": "AgentNet Standalone Agent - Autonomous AI Agent with zero external dependencies",
  "main": "src/standalone-agent.js",
  "bin": {
    "agentnet-agent": "src/standalone-agent.js"
  },
  "scripts": {
    "start": "node src/standalone-agent.js",
    "setup": "node src/standalone-agent.js --setup",
    "config": "node src/standalone-agent.js --config-panel",
    "check": "node src/standalone-agent.js --self-check",
    "version": "node src/standalone-agent.js --version",
    "release": "npm run release:clean && npm run release:pack:all",
    "release:clean": "node -e \"const fs=require('fs'); fs.rmSync('dist', { recursive: true, force: true }); fs.mkdirSync('dist', { recursive: true });\"",
    "release:pack": "node scripts/release-pack.js",
    "release:pack:all": "node scripts/release-pack.js --platform all",
    "release:pack:linux": "node scripts/release-pack.js --platform linux-x64",
    "release:pack:linux-arm": "node scripts/release-pack.js --platform linux-arm64",
    "release:pack:mac": "node scripts/release-pack.js --platform darwin-x64",
    "release:pack:mac-arm": "node scripts/release-pack.js --platform darwin-arm64",
    "release:pack:win": "node scripts/release-pack.js --platform win-x64",
    "release:verify": "node scripts/release-pack.js --verify",
    "build:sea:linux": "node scripts/release-pack.js --platform linux-x64 --compat-mode=sea",
    "build:sea:linux-arm": "node scripts/release-pack.js --platform linux-arm64 --compat-mode=sea",
    "build:sea:mac": "node scripts/release-pack.js --platform darwin-x64 --compat-mode=sea",
    "build:sea:mac-arm": "node scripts/release-pack.js --platform darwin-arm64 --compat-mode=sea",
    "build:sea:win": "node scripts/release-pack.js --platform win-x64 --compat-mode=sea",
    "build": "node -e \"const fs=require('fs');fs.accessSync('src/standalone-agent.js');console.log('agent-ready')\"",
    "test": "node src/standalone-agent.js --version"
  },
  "dependencies": {
    "axios": "^1.6.0"
  },
  "optionalDependencies": {
    "better-sqlite3": "^9.4.3",
    "chalk": "^4.1.2",
    "express": "^4.18.2",
    "ws": "^8.16.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "os": ["win32", "linux", "darwin"],
  "cpu": ["x64", "arm64"],
  "files": [
    "src/",
    "config/",
    "scripts/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "agentnet",
    "agent",
    "autonomous",
    "standalone",
    "ai",
    "cross-platform"
  ],
  "author": "AgentNet Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/agentnet/agent.git"
  },
  "homepage": "https://agentnet.ai"
}
