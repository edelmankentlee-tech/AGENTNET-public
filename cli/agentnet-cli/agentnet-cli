#!/bin/bash
#
# AgentNet CLI - е‘Ҫд»ӨиЎҢе·Ҙе…·
#
# з”Ёжі•:
#   agentnet-cli task create --type shopping --input '{"query":"laptop"}'
#   agentnet-cli task list --status pending
#   agentnet-cli capability search --tag ecommerce
#   agentnet-cli agent status
#

set -e

# й…ҚзҪ®
VERSION="1.0.0"
API_BASE_URL="${AGENTNET_API_URL:-https://api.agentnet.ai}"
CLI_DIR="${HOME}/.agentnet-cli"

# йўңиүІиҫ“еҮә
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# жү“еҚ°еҮҪж•°
print_info() { echo -e "${BLUE}[INFO]${NC} $1"; }
print_success() { echo -e "${GREEN}[OK]${NC} $1"; }
print_error() { echo -e "${RED}[ERROR]${NC} $1"; }
print_warning() { echo -e "${YELLOW}[WARN]${NC} $1"; }

# её®еҠ©дҝЎжҒҜ
show_help() {
    cat << EOF
AgentNet CLI - AgentNet Protocol V3 е‘Ҫд»ӨиЎҢе·Ҙе…·

з”Ёжі•:
    agentnet-cli <command> [options]

е‘Ҫд»Ө:
    task <action>       д»»еҠЎз®ЎзҗҶ (create, list, get, cancel, retry)
    capability <action> иғҪеҠӣз®ЎзҗҶ (list, search, info, call)
    agent <action>      Agent з®ЎзҗҶ (status, register)
    decision <action>   еҶізӯ–з®ЎзҗҶ (list, confirm, reject)
    config              й…ҚзҪ®з®ЎзҗҶ
    help                жҳҫзӨәеё®еҠ©

зӨәдҫӢ:
    agentnet-cli task create --type shopping --input '{"query":"laptop"}'
    agentnet-cli task list --status pending
    agentnet-cli capability search --tag ecommerce
    agentnet-cli agent status

йҖүйЎ№:
    --help, -h     жҳҫзӨәеё®еҠ©
    --version, -v жҳҫзӨәзүҲжң¬
    --debug        и°ғиҜ•жЁЎејҸ
    --api-url      жҢҮе®ҡ API ең°еқҖ

жӣҙеӨҡдҝЎжҒҜ: https://docs.agentnet.ai
EOF
}

# жЈҖжҹҘ API Key
check_api_key() {
    if [ -z "$AGENTNET_API_KEY" ]; then
        if [ -f "${CLI_DIR}/api_key" ]; then
            export AGENTNET_API_KEY=$(cat "${CLI_DIR}/api_key")
        else
            print_error "иҜ·и®ҫзҪ® AGENTNET_API_KEY зҺҜеўғеҸҳйҮҸ"
            print_info "жҲ–иҝҗиЎҢ: agentnet-cli config set-api-key <your-key>"
            exit 1
        fi
    fi
}

# HTTP иҜ·жұӮ
api_request() {
    local method=$1
    local endpoint=$2
    local data=$3

    check_api_key

    local curl_cmd="curl -s -X ${method}"
    curl_cmd="${curl_cmd} -H 'Authorization: Bearer ${AGENTNET_API_KEY}'"
    curl_cmd="${curl_cmd} -H 'Content-Type: application/json'"
    curl_cmd="${curl_cmd} -H 'Accept: application/json'"

    if [ -n "$data" ]; then
        curl_cmd="${curl_cmd} -d '${data}'"
    fi

    curl_cmd="${curl_cmd} '${API_BASE_URL}${endpoint}'"

    eval $curl_cmd
}

# ===================== Task е‘Ҫд»Ө =====================

cmd_task() {
    local action=${1:-help}

    case $action in
        create)
            shift
            cmd_task_create "$@"
            ;;
        list)
            shift
            cmd_task_list "$@"
            ;;
        get)
            shift
            cmd_task_get "$@"
            ;;
        cancel)
            shift
            cmd_task_cancel "$@"
            ;;
        retry)
            shift
            cmd_task_retry "$@"
            ;;
        *)
            print_error "жңӘзҹҘд»»еҠЎе‘Ҫд»Ө: $action"
            echo "дҪҝз”Ё: agentnet-cli task [create|list|get|cancel|retry]"
            exit 1
            ;;
    esac
}

cmd_task_create() {
    local task_type="generic"
    local input='{}'
    local priority="normal"

    while [[ $# -gt 0 ]]; do
        case $1 in
            --type) task_type="$2"; shift 2 ;;
            --input) input="$2"; shift 2 ;;
            --priority) priority="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local payload=$(cat << EOF
{
    "type": "${task_type}",
    "input": ${input},
    "priority": "${priority}"
}
EOF
)

    print_info "еҲӣе»әд»»еҠЎ..."
    local response=$(api_request "POST" "/api/v3/tasks" "$payload")
    local task_id=$(echo $response | grep -o '"task_id":"[^"]*"' | cut -d'"' -f4)

    if [ -n "$task_id" ]; then
        print_success "д»»еҠЎеҲӣе»әжҲҗеҠҹ: ${task_id}"
        echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
    else
        print_error "д»»еҠЎеҲӣе»әеӨұиҙҘ"
        echo "$response"
        exit 1
    fi
}

cmd_task_list() {
    local status=""
    local limit=20

    while [[ $# -gt 0 ]]; do
        case $1 in
            --status) status="$2"; shift 2 ;;
            --limit) limit="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local endpoint="/api/v3/tasks?limit=${limit}"
    [ -n "$status" ] && endpoint="${endpoint}&status=${status}"

    print_info "иҺ·еҸ–д»»еҠЎеҲ—иЎЁ..."
    local response=$(api_request "GET" "${endpoint}" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_task_get() {
    local task_id=$1

    if [ -z "$task_id" ]; then
        print_error "иҜ·жҢҮе®ҡд»»еҠЎ ID"
        echo "дҪҝз”Ё: agentnet-cli task get <task_id>"
        exit 1
    fi

    print_info "иҺ·еҸ–д»»еҠЎиҜҰжғ…: ${task_id}..."
    local response=$(api_request "GET" "/api/v3/tasks/${task_id}" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_task_cancel() {
    local task_id=$1

    if [ -z "$task_id" ]; then
        print_error "иҜ·жҢҮе®ҡд»»еҠЎ ID"
        exit 1
    fi

    print_info "еҸ–ж¶Ҳд»»еҠЎ: ${task_id}..."
    local response=$(api_request "POST" "/api/v3/tasks/${task_id}/cancel" '{"reason":"user cancelled"}')

    print_success "д»»еҠЎе·ІеҸ–ж¶Ҳ"
    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_task_retry() {
    local task_id=$1

    if [ -z "$task_id" ]; then
        print_error "иҜ·жҢҮе®ҡд»»еҠЎ ID"
        exit 1
    fi

    print_info "йҮҚиҜ•д»»еҠЎ: ${task_id}..."
    local response=$(api_request "POST" "/api/v3/tasks/${task_id}/retry" "")

    print_success "д»»еҠЎйҮҚиҜ•е·Іи§ҰеҸ‘"
    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

# ===================== Capability е‘Ҫд»Ө =====================

cmd_capability() {
    local action=${1:-help}

    case $action in
        list)
            shift
            cmd_capability_list "$@"
            ;;
        search)
            shift
            cmd_capability_search "$@"
            ;;
        info)
            shift
            cmd_capability_info "$@"
            ;;
        *)
            print_error "жңӘзҹҘиғҪеҠӣе‘Ҫд»Ө: $action"
            echo "дҪҝз”Ё: agentnet-cli capability [list|search|info]"
            exit 1
            ;;
    esac
}

cmd_capability_list() {
    print_info "иҺ·еҸ–иғҪеҠӣеҲ—иЎЁ..."
    local response=$(api_request "GET" "/api/v3/capabilities" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_capability_search() {
    local tag=""
    local risk_level=""

    while [[ $# -gt 0 ]]; do
        case $1 in
            --tag) tag="$2"; shift 2 ;;
            --risk) risk_level="$2"; shift 2 ;;
            *) shift ;;
        esac
    done

    local endpoint="/api/v3/capabilities?"
    [ -n "$tag" ] && endpoint="${endpoint}tags=${tag}&"
    [ -n "$risk_level" ] && endpoint="${endpoint}risk_level=${risk_level}"

    print_info "жҗңзҙўиғҪеҠӣ..."
    local response=$(api_request "GET" "${endpoint}" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_capability_info() {
    local capability_id=$1

    if [ -z "$capability_id" ]; then
        print_error "иҜ·жҢҮе®ҡиғҪеҠӣ ID"
        echo "дҪҝз”Ё: agentnet-cli capability info <capability_id>"
        exit 1
    fi

    print_info "иҺ·еҸ–иғҪеҠӣиҜҰжғ…: ${capability_id}..."
    local response=$(api_request "GET" "/api/v3/capabilities/${capability_id}" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

# ===================== Agent е‘Ҫд»Ө =====================

cmd_agent() {
    local action=${1:-status}

    case $action in
        status)
            shift
            cmd_agent_status "$@"
            ;;
        register)
            shift
            cmd_agent_register "$@"
            ;;
        *)
            print_error "жңӘзҹҘ Agent е‘Ҫд»Ө: $action"
            echo "дҪҝз”Ё: agentnet-cli agent [status|register]"
            exit 1
            ;;
    esac
}

cmd_agent_status() {
    print_info "иҺ·еҸ– Agent зҠ¶жҖҒ..."
    local response=$(api_request "GET" "/api/v3/agents/me" "")

    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

cmd_agent_register() {
    local agent_id=$1

    if [ -z "$agent_id" ]; then
        print_error "иҜ·жҢҮе®ҡ Agent ID"
        echo "дҪҝз”Ё: agentnet-cli agent register <agent_id>"
        exit 1
    fi

    local payload=$(cat << EOF
{
    "agent_id": "${agent_id}",
    "name": "${agent_id}",
    "capabilities": []
}
EOF
)

    print_info "жіЁеҶҢ Agent: ${agent_id}..."
    local response=$(api_request "POST" "/api/v3/agents" "$payload")

    print_success "Agent жіЁеҶҢжҲҗеҠҹ"
    echo "$response" | python3 -m json.tool 2>/dev/null || echo "$response"
}

# ===================== дё»е…ҘеҸЈ =====================

main() {
    if [ $# -eq 0 ]; then
        show_help
        exit 0
    fi

    local command=$1
    shift

    case $command in
        task) cmd_task "$@" ;;
        capability) cmd_capability "$@" ;;
        agent) cmd_agent "$@" ;;
        config) cmd_config "$@" ;;
        help|--help|-h) show_help ;;
        version|--version|-v) echo "agentnet-cli version ${VERSION}" ;;
        *) print_error "жңӘзҹҘе‘Ҫд»Ө: $command"; show_help; exit 1 ;;
    esac
}

# й…ҚзҪ®е‘Ҫд»Ө
cmd_config() {
    local action=${1:-show}

    case $action in
        show)
            echo "AgentNet CLI й…ҚзҪ®:"
            echo "  API URL: ${API_BASE_URL}"
            [ -n "$AGENTNET_API_KEY" ] && echo "  API Key: ${AGENTNET_API_KEY:0:8}..." || echo "  API Key: (жңӘи®ҫзҪ®)"
            ;;
        set-api-url)
            mkdir -p "${CLI_DIR}"
            echo "$2" > "${CLI_DIR}/api_url"
            print_success "API URL е·Іи®ҫзҪ®"
            ;;
        set-api-key)
            mkdir -p "${CLI_DIR}"
            echo "$2" > "${CLI_DIR}/api_key"
            print_success "API Key е·Іи®ҫзҪ®"
            ;;
        *)
            cmd_config show
            ;;
    esac
}

main "$@"
